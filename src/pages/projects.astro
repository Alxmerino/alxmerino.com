---
import Github from '../components/icons/github.astro';
import React from '../components/icons/react.astro';
import Typescript from '../components/icons/typescript.astro';

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
	<main class="px-6 md:px-0 max-w-xl m-auto">
        <h1 class="text-5xl mb-4">Projects</h1>
        
        <hr class="mb-10" />
        
        <article class="mb-20">
			<h2 class="text-4xl mb-3">
                <a href="https://binderbuilder.app" target="_blank">BinderBuilder.app</a>
            </h2>
			<p>A collection tracker for Pokemon TCG collectors who need to track print variants, not just unique cards. Binder Builder covers 1,025 Pokemon across 412 sets with 69,754 trackable variants — Holo, Reverse Holo, 1st Edition, Shadowless, and more — all stored locally in the browser with no account required.</p>

            <h4 class="text-xl mt-5 mb-2">Tech Stack</h4>
            <ul class="flex space-x-3 items-center">
                <li><a  target="_blank" href="http://www.typescriptlang.org/" title="TypeScript"><Typescript class="h-5" /><span class="sr-only">TypeScript</span></a></li>
                <li><a  target="_blank" href="https://reactjs.org/" title="React"><React class="h-5" /><span class="sr-only">React</span></a></li>
            </ul>
		</article>

        <article class="mb-20">
			<h2 class="text-4xl mb-3">
                <a href="https://github.com/Alxmerino/craft-locked-entries" target="_blank">Locked Entries for Craft CMS</a>
            </h2>

			<p>A Craft CMS plugin that gives users the ability to mark entries as locked so only they can edit them, keeping ownership clear on large multi-author sites. Administrators can override locks when needed for smooth collaboration.</p>

            <h4 class="text-xl mt-5 mb-2">Tech Stack</h4>
            <ul class="flex space-x-3 items-center">
                <li><a  target="_blank" href="https://github.com/Alxmerino/craft-locked-entries" title="See Project Code"><Github class="h-5" /><span class="sr-only">See Project Code</span></a></li>
            </ul>
		</article>
		
	</main>
</BaseLayout>